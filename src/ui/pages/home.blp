using Gtk 4.0;
using Adw 1;

template $NocturneHomePage: Adw.NavigationPage {
  title: _("Home");
  child: Adw.ToolbarView {
    [top]
    Adw.HeaderBar {}

    content: Gtk.ScrolledWindow {
      propagate-natural-width: true;
      propagate-natural-height: true;

      child: Adw.Clamp {
        maximum-size: 2000;
        tightening-threshold: 800;

        child: Gtk.Box {
          orientation: vertical;
          spacing: 10;

          $NocturneCarousel album_carousel {}

          Gtk.Separator {
            margin-start: 10;
            margin-end: 10;
          }

          $NocturneCarousel artist_carousel {}

          Gtk.Separator {
            margin-start: 10;
            margin-end: 10;
          }

          $NocturneCarousel playlist_carousel {}
        };


      };

    };
  };
}